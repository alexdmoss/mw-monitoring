{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)alertmanager\\.ya?ml$/"],
      "matchStrings": ["image:\\s*(?<depName>[^\\s:]+):(?<currentValue>\\S+)"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)prometheus\\.ya?ml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "baseImage:\\s*(?<depName>\\S+)",
        "version:\\s*(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)\\.gitlab-ci\\.yml$/"],
      "matchStrings": ["--image-name=\"(?<depName>[^\"]+)\"\\s+--image-tag=\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
